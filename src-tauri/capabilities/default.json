{
  "$schema": "https://schema.tauri.app/config/2/capabilities",
  "identifier": "default",
  "description": "Default capabilities for the Aster Mail desktop app",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:tray:default",
    "core:menu:default",
    "shell:allow-open",
    "clipboard-manager:allow-read-text",
    "clipboard-manager:allow-write-text",
    "notification:default",
    "core:event:default",
    "updater:default",
    "process:default",
    "process:allow-restart",
    "dialog:default"
  ]
}
